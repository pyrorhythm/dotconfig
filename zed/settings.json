    "collaboration_panel": {
        "dock": "right",
        "button": true,
    },
    "git_panel": {
        "file_icons": true,
        "status_style": "label_color",
        "dock": "bottom",
        "button": true,
    },
    "outline_panel": {
        "dock": "right",
        "button": true,
    },
    "project_panel": {
        "button": false,
        "git_status_indicator": true,
        "diagnostic_badges": false,
        "bold_folder_labels": true,
        "starts_open": true,
        "hide_hidden": true,
        "auto_reveal_entries": true,
        "indent_size": 14.0,
        "git_status": true,
        "folder_icons": true,
        "file_icons": true,
        "entry_spacing": "standard",
        "hide_gitignore": false,
        "default_width": 200.0,
        "dock": "left",
    },
    "show_completion_documentation": true,
    "completions": {
        "words": "enabled",
    },
    "inlay_hints": {
        "show_background": false,
        "show_parameter_hints": false,
        "show_value_hints": true,
        "enabled": true,
    },
    "lsp_document_colors": "inlay",
    "colorize_brackets": true,
    "indent_guides": {
        "background_coloring": "disabled",
        "coloring": "indent_aware",
        "active_line_width": 3,
        "line_width": 1,
    },
    "tab_size": 4,
    "scrollbar": {
        "axes": {
            "horizontal": false,
        },
        "diagnostics": "error",
        "git_diff": false,
        "show": "never",
    },
    "inline_code_actions": false,
    "relative_line_numbers": "disabled",
    "unnecessary_code_fade": 0.6,
    "diagnostics": {
        "button": true,
        "lsp_pull_diagnostics": {
            "debounce_ms": 90,
        },
        "inline": {
            "enabled": true,
        },
        "include_warnings": true,
    },
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)"
    },
    "terminal": {
        "toolbar": {
            "breadcrumbs": false
        },
        "font_features": {
            "dlig": true,
            "cv59": true,
            "cv30": true,
            "ss20": true,
            "ss18": true,
            "ss11": true,
            "ss08": true,
            "ss05": true,
            "ss01": true,
        },
        "button": false,
        "show_count_badge": false,
        "flexible": true,
        "default_height": 240.0,
        "font_weight": 450.0,
        "font_size": 14.0,
        "dock": "bottom",
        "cursor_shape": "hollow",
        "font_family": "Hack Nerd Font Mono",
        "line_height": "standard",
    },
    "search": {
        "button": false,
        "include_ignored": false,
        "regex": true,
    },
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "tab_bar": {
        "show_nav_history_buttons": false,
        "show_tab_bar_buttons": false,
        "show_pinned_tabs_in_separate_row": false,
        "show": false,
    },
    "minimap": {
        "current_line_highlight": "all",
        "thumb": "hover",
        "show": "always",
    },
    "cursor_shape": "hollow",
    "cursor_blink": true,
    "current_line_highlight": "all",
    "autosave": "on_focus_change",
    "ui_font_weight": 500.0,
    "ui_font_family": "Geist",
    "ui_font_size": 14.0,
    "ui_font_features": {
        "ss01": true,
        "ss02": true,
        "ss03": true,
        "ss04": true,
        "ss05": true,
    },
    "buffer_font_fallbacks": ["Iosevka"],
    "buffer_font_family": "GeistMono Nerd Font Mono",
    "buffer_font_features": {
        "dlig": true,
        "cv59": true,
        "cv30": true,
        "ss20": true,
        "ss18": true,
        "ss11": true,
        "ss08": true,
        "ss05": true,
        "ss01": true,
    },
    "buffer_line_height": {
        "custom": 1.3000000715255737,
    },
    "buffer_font_size": 14.0,
    "buffer_font_weight": 500.0,
    "soft_wrap": "editor_width",
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "shhhed",
    },
    "languages": {
        "YAML": {
            "tab_size": 2
        },
        "JSON": {
            "show_edit_predictions": true,
        },
        "Proto": {
            "show_edit_predictions": true,
            "language_servers": ["protobuf-language-server"],
        },
        "Nix": {
            "show_edit_predictions": false,
        },
        "Go": {
            "show_edit_predictions": true,
            "format_on_save": "on",
            "language_servers": ["gopls", "golangci-lint"],
            "code_actions_on_format": {
                "source.organizeImports": true,
                "source.fixAll": true,
            },
        },
        "Python": {
            "show_edit_predictions": true,
            "tab_size": 2,
            "indent_guides": {
                "background_coloring": "disabled",
                "coloring": "indent_aware",
            },
            "preferred_line_length": 120,
            "soft_wrap": "prefer_line",
            "hard_tabs": true,
            "inlay_hints": {
                "show_parameter_hints": false,
                "show_background": false,
                "show_other_hints": true,
                "enabled": true,
            },
            "language_servers": ["ruff", "!ty"],
            "code_actions_on_format": {
                "source.organizeImports.ruff": true,
                "source.fixAll.ruff": true,
                "source.fixAll.pyrefly": true,
            },
            "formatter": {
                "language_server": {
                    "name": "ruff",
                },
            },
            "format_on_save": "on",
            "show_completion_documentation": true,
        },
    },
    "lsp": {
        "protobuf-language-server": {
            "binary": {
                "path": "$HOME/.cargo/bin/protobuf-lsp",
            },
        },
        "gopls": {
            "initialization_options": {
                "directoryFilters": ["-**/node_modules", "-**/.git"],
                "formatting.gofumpt": false,
                "symbolScope": "workspace",
                "staticcheck": true,
                "usePlaceholders": false,
                "templateExtensions": ["templ", "tmpl"],
                "experimentalPostfixCompletions": true,
                "analyses": {
                    "nilness": true,
                    "unusedparams": true,
                    "unusedvariable": true,
                    "unusedwrite": true,
                    "useany": true,
                    "ST1000": false,
                    "ST1001": false,
                    "ST1003": false,
                },
                "codelenses": {
                    "gc_details": true,
                },
                "hints": {
                    "assignVariableTypes": true,
                    "compositeLiteralFields": true,
                    "compositeLiteralTypes": false,
                    "constantValues": true,
                    "functionTypeParameters": false,
                    "parameterNames": true,
                    "rangeVariableTypes": true,
                },
            },
        },
    },
    "auto_install_extensions": {
        "dockerfile": true,
        "git-firefly": true,
        "golangci-lint": true,
        "gosum": true,
        "jetbrains-rider": true,
        "just": true,
        "make": true,
        "meson": true,
        "monospace-icon-theme": true,
        "neocmake": true,
        "nix": true,
        "package-swift-lsp": true,
        "proto": true,
        "pyrefly": true,
        "sql": true,
        "svelte": true,
        "swift": true,
        "toml": true,
        "xml": true,
        "zedokai": true,
    },
}
